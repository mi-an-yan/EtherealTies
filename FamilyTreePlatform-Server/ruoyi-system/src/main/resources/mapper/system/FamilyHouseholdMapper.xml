<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.familytree.platform.system.mapper.FamilyHouseholdMapper">
    <resultMap type="com.familytree.platform.system.domain.FamilyHousehold" id="FamilyHouseholdResult">
        <id     property="id"           column="id"           />
        <result property="householdName" column="household_name" />
        <result property="address"      column="address"      />
        <result property="foundingDate"  column="founding_date"  />
        <result property="description"  column="description"  />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <resultMap type="com.familytree.platform.system.domain.FamilyPersonHousehold" id="FamilyPersonHouseholdResult">
        <id     property="id"                column="id"                />
        <result property="personId"          column="person_id"          />
        <result property="householdId"       column="household_id"       />
        <result property="relationshipType"  column="relationship_type"  />
        <result property="joinDate"          column="join_date"          />
        <result property="leaveDate"         column="leave_date"         />
        <result property="createBy"          column="create_by"          />
        <result property="createTime"        column="create_time"        />
        <result property="updateBy"          column="update_by"          />
        <result property="updateTime"        column="update_time"        />
    </resultMap>

    <sql id="selectFamilyHouseholdVo">
        select id, household_name, address, founding_date, description, create_by, create_time, update_by, update_time from family_household
    </sql>

    <sql id="selectFamilyPersonHouseholdVo">
        select id, person_id, household_id, relationship_type, join_date, leave_date, create_by, create_time, update_by, update_time from family_person_household
    </sql>

    <select id="selectFamilyHouseholdById" parameterType="Long" resultMap="FamilyHouseholdResult">
        <include refid="selectFamilyHouseholdVo" />
        where id = #{id}
    </select>

    <select id="selectFamilyHouseholdList" parameterType="com.familytree.platform.system.domain.FamilyHousehold" resultMap="FamilyHouseholdResult">
        <include refid="selectFamilyHouseholdVo" />
        <where>
            <if test="householdName != null and householdName != ''">
                AND household_name like concat('%', #{householdName}, '%')
            </if>
            <if test="address != null and address != ''">
                AND address like concat('%', #{address}, '%')
            </if>
            <if test="foundingDate != null">
                AND founding_date = #{foundingDate}
            </if>
        </where>
    </select>

    <insert id="insertFamilyHousehold" parameterType="com.familytree.platform.system.domain.FamilyHousehold" useGeneratedKeys="true" keyProperty="id">
        insert into family_household
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="householdName != null">household_name,</if>
            <if test="address != null">address,</if>
            <if test="foundingDate != null">founding_date,</if>
            <if test="description != null">description,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="householdName != null">#{householdName},</if>
            <if test="address != null">#{address},</if>
            <if test="foundingDate != null">#{foundingDate},</if>
            <if test="description != null">#{description},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateFamilyHousehold" parameterType="com.familytree.platform.system.domain.FamilyHousehold">
        update family_household
        <set>
            <if test="householdName != null">household_name = #{householdName},</if>
            <if test="address != null">address = #{address},</if>
            <if test="foundingDate != null">founding_date = #{foundingDate},</if>
            <if test="description != null">description = #{description},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteFamilyHouseholdById" parameterType="Long">
        delete from family_household where id = #{id}
    </delete>

    <delete id="deleteFamilyHouseholdByIds" parameterType="Long[]">
        delete from family_household where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectHouseholdMembers" parameterType="Long" resultMap="FamilyPersonHouseholdResult">
        <include refid="selectFamilyPersonHouseholdVo" />
        where household_id = #{householdId}
    </select>

    <select id="selectPersonHouseholds" parameterType="Long" resultMap="FamilyPersonHouseholdResult">
        <include refid="selectFamilyPersonHouseholdVo" />
        where person_id = #{personId}
    </select>

    <insert id="insertFamilyPersonHousehold" parameterType="com.familytree.platform.system.domain.FamilyPersonHousehold" useGeneratedKeys="true" keyProperty="id">
        insert into family_person_household
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="personId != null">person_id,</if>
            <if test="householdId != null">household_id,</if>
            <if test="relationshipType != null">relationship_type,</if>
            <if test="joinDate != null">join_date,</if>
            <if test="leaveDate != null">leave_date,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="personId != null">#{personId},</if>
            <if test="householdId != null">#{householdId},</if>
            <if test="relationshipType != null">#{relationshipType},</if>
            <if test="joinDate != null">#{joinDate},</if>
            <if test="leaveDate != null">#{leaveDate},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateFamilyPersonHousehold" parameterType="com.familytree.platform.system.domain.FamilyPersonHousehold">
        update family_person_household
        <set>
            <if test="relationshipType != null">relationship_type = #{relationshipType},</if>
            <if test="joinDate != null">join_date = #{joinDate},</if>
            <if test="leaveDate != null">leave_date = #{leaveDate},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteFamilyPersonHouseholdById" parameterType="Long">
        delete from family_person_household where id = #{id}
    </delete>

    <delete id="deleteFamilyPersonHouseholdByIds" parameterType="Long[]">
        delete from family_person_household where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
